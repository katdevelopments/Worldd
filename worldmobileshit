			{ Size = UDim2.new(0, 0, 0, 0) }
		)
		tween:Play()
		tween.Completed:Wait()
		if tutorialFrame.Parent then
			tutorialFrame:Destroy()
		end
	end

	table.insert(
		connections,
		prevButton.MouseButton1Click:Connect(function()
			if currentPage > 1 then
				currentPage -= 1
				updatePage()
			end
		end)
	)
	table.insert(
		connections,
		nextButton.MouseButton1Click:Connect(function()
			if currentPage < #pages then
				currentPage += 1
				updatePage()
			else
				closeTutorial()
			end
		end)
	)
	table.insert(
		connections,
		skipButton.MouseButton1Click:Connect(function()
			createClickParticles(skipButton)
			closeTutorial()
		end)
	)
	updatePage()
end

