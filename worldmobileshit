			TweenService:Create(addTabButton, TweenInfo.new(0.15), { BackgroundColor3 = CONFIG.Colors.UtilButton })
				:Play()
		end)
	)

	-- Mirror typing into the active tab (debounced disk save)
	table.insert(
		connections,
		inputBox:GetPropertyChangedSignal("Text"):Connect(function()
			if switchingTabs then
				return
			end
			if editorTabs[activeTabIndex] then
				editorTabs[activeTabIndex].content = inputBox.Text
				debouncedSaveTabs()
			end
		end)
	)

	table.insert(themedUpdaters, function(theme, fontData)
		tintTween(addTabButton, { BackgroundColor3 = theme.UtilButton })
		addTabButton.Font = fontData.Bold
		tintTween(tabBar, { ScrollBarImageColor3 = theme.PrimaryAccent })
		tintTween(tabMenu, { BackgroundColor3 = theme.Background })
		tintTween(tabMenuStroke, { Color = theme.SecondaryAccent })
		tintTween(renameFrame, { BackgroundColor3 = theme.Background })
		tintTween(renameStroke, { Color = theme.SecondaryAccent })
		tintTween(renameTitle, { TextColor3 = theme.Text })
		tintTween(renameBox, { BackgroundColor3 = theme.UtilButton, TextColor3 = theme.Text })
		tintTween(renameConfirm, { BackgroundColor3 = theme.SecondaryAccent })
		tintTween(renameCancel, { BackgroundColor3 = theme.UtilButton, TextColor3 = theme.Text })
		refreshTabBar()
	end)

	-- Load the active tab's content into the editor at startup
	switchingTabs = true
	inputBox.Text = editorTabs[activeTabIndex] and editorTabs[activeTabIndex].content or ""
	switchingTabs = false
	refreshTabBar()
end

