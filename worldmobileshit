		-- Auto-detect open tabs and add to AE list if not present
		local existing = {}
		for _, v in ipairs(autoExecScripts) do
			existing[v.Name] = v
		end
		local updated = false
		for _, tab in ipairs(editorTabs) do
			if tab.name and tab.name ~= "" and not existing[tab.name] then
				table.insert(autoExecScripts, { Name = tab.name, Source = tab.content, Enabled = false })
				existing[tab.name] = autoExecScripts[#autoExecScripts]
				updated = true
			elseif tab.name and tab.name ~= "" and existing[tab.name] then
				-- Optionally update the source to latest editor content (maybe risky but makes sense for "detected tabs")
