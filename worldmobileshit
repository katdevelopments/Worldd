function applySettings()
	local theme = themes[currentThemeIndex].Colors
	local fontData = fontsList[currentFontIndex]

	CONFIG.Colors = theme
	CONFIG.Font = fontData.Font
	CONFIG.BoldFont = fontData.Bold

	-- Fonts can't be tweened, so apply those instantly; every color property
	-- is eased so theme/font switches glide instead of snapping.
	titleLabel.Font = fontData.Bold
	runButton.Font = fontData.Bold
	inputBox.Font = fontData.Font

	tintTween(blurFrame, { BackgroundColor3 = theme.Background })
	tintTween(blurStroke, { Color = theme.PrimaryAccent })
	tintTween(titleLabel, { TextColor3 = theme.Text })
	tintTween(logContainer, { ScrollBarImageColor3 = theme.PrimaryAccent })
	tintTween(runButton, { BackgroundColor3 = runButtonHovered and theme.PrimaryAccent or theme.SecondaryAccent })
	tintTween(inputContainer, { ScrollBarImageColor3 = theme.Text })
	tintTween(inputBox, { TextColor3 = theme.Text })

	local tutFrame = screenGui:FindFirstChild("TutorialFrame")
	if tutFrame then
		tintTween(tutFrame, { BackgroundColor3 = theme.Background })
		local tStroke = tutFrame:FindFirstChildOfClass("UIStroke")
		if tStroke then
			tintTween(tStroke, { Color = theme.PrimaryAccent })
		end
		local tTitle = tutFrame:FindFirstChild("TextLabel")
		if tTitle then
			tintTween(tTitle, { TextColor3 = theme.Text })
			tTitle.Font = fontData.Bold
		end
	end

	for i = #utilButtons, 1, -1 do
		local btn = utilButtons[i]
		if not btn.Parent then
			table.remove(utilButtons, i)
		else
			tintTween(btn, { BackgroundColor3 = theme[btn:GetAttribute("ColorType")] })
		end
	end

	for _, frame in ipairs(activeLogFrames) do
		if frame and frame.Parent then
			local entry = frame:FindFirstChild("LogEntry")
			if entry then
				entry.Font = fontData.Font
				entry.TextSize = CONFIG.TextSize
				local typeAttr = entry:GetAttribute("LogType")
				local target
				if typeAttr == "Error" then
					target = theme.Error
				elseif typeAttr == "Warning" then
					target = theme.Warning
				elseif typeAttr == "Input" then
					target = theme.InputEcho
				elseif typeAttr == "Info" then
					target = theme.Info
				else
					target = theme.Text
				end
				tintTween(entry, { TextColor3 = target })
			end
		end
	end

	tintTween(settingsFrame, { BackgroundColor3 = theme.Background })
	tintTween(settingsStroke, { Color = theme.PrimaryAccent })
	tintTween(settingsTitle, { TextColor3 = theme.Text })
	settingsTitle.Font = fontData.Bold

	for _, updater in ipairs(themedUpdaters) do
		pcall(updater, theme, fontData)
	end

	strokeGradient.Color = ColorSequence.new({
		ColorSequenceKeypoint.new(0, theme.PrimaryAccent),
		ColorSequenceKeypoint.new(0.5, theme.SecondaryAccent),
		ColorSequenceKeypoint.new(1, theme.PrimaryAccent),
	})

	inputBox.TextSize = CONFIG.TextSize
	templateEntry.TextSize = CONFIG.TextSize
	templateEntry.Font = fontData.Font
	refreshInputHighlight()
end

local function toggleSettings()
	local willBeVisible = not settingsFrame.Visible
	if willBeVisible then
		settingsOverlay.Visible = true
		settingsFrame.Visible = true
		TweenService:Create(settingsOverlay, TweenInfo.new(0.3), { BackgroundTransparency = 0.6 }):Play()
		settingsScale.Scale = 0
		TweenService
			:Create(settingsScale, TweenInfo.new(0.3, Enum.EasingStyle.Back, Enum.EasingDirection.Out), { Scale = 1 })
			:Play()
	else
		closePicker(true)
		TweenService:Create(settingsOverlay, TweenInfo.new(0.3), { BackgroundTransparency = 1 }):Play()
		local tw = TweenService:Create(
			settingsScale,
			TweenInfo.new(0.25, Enum.EasingStyle.Back, Enum.EasingDirection.In),
			{ Scale = 0 }
		)
		tw:Play()
		tw.Completed:Wait()
		settingsOverlay.Visible = false
		settingsFrame.Visible = false
	end
end

