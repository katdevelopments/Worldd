    Instance.new("UICorner", pinButton).CornerRadius = UDim.new(0, 6)
    addDepthGradient(pinButton)
    safeSetCursor(pinButton, "rbxasset://SystemCursor/Arrow")

    local pinned = true
    local suppressScrollDetect = false

    local function updatePinVisual()
        local colorType = pinned and "SecondaryAccent" or "UtilButton"
        pinButton:SetAttribute("ColorType", colorType)
        TweenService:Create(pinButton, TweenInfo.new(0.15), {BackgroundColor3 = CONFIG.Colors[colorType]}):Play()
    end

    function scrollLogsToBottom(force)
        if force and not pinned then
            pinned = true
            updatePinVisual()
        end
        if not pinned then return end
        suppressScrollDetect = true
        task.defer(function()
            logContainer.CanvasPosition = Vector2.new(0, math.max(0, logContainer.AbsoluteCanvasSize.Y))
            task.delay(0.05, function() suppressScrollDetect = false end)
        end)
    end

    table.insert(connections, pinButton.MouseButton1Click:Connect(function()
        pinned = not pinned
        updatePinVisual()
        if pinned then scrollLogsToBottom(true) end
    end))

    -- Scrolling up suspends auto-scroll; returning to the bottom re-arms it
    table.insert(connections, logContainer:GetPropertyChangedSignal("CanvasPosition"):Connect(function()
        if suppressScrollDetect then return end
        local maxScroll = logContainer.AbsoluteCanvasSize.Y - logContainer.AbsoluteSize.Y
        if maxScroll <= 0 then return end
        local nearBottom = logContainer.CanvasPosition.Y >= maxScroll - 40
        if nearBottom ~= pinned then
            pinned = nearBottom
            updatePinVisual()
        end
    end))

