    for _, key in ipairs({"glowTransparency", "glowThickness", "strokeSpin"}) do
        if activeTweens[key] then activeTweens[key]:Cancel() activeTweens[key] = nil end
    end
    TweenService:Create(blurStroke, TweenInfo.new(0.3), {Transparency = 0.2, Thickness = 2}):Play()
