function log(message, messageType, bulkLoad)
	isLoggingInternally = true
	logCounter += 1

	local logFrame = templateLog:Clone()
	logFrame.LayoutOrder = logCounter
	local logEntry = logFrame.LogEntry
	local logLine = logFrame:FindFirstChild("LineNumber")
	if logLine then logLine.Text = tostring(logCounter) end
	local messageStr = tostring(message)

	logEntry:SetAttribute("LogType", messageType)
	logFrame:SetAttribute("LogType", messageType)
	logFrame:SetAttribute("RawText", messageStr)

	if messageType == "Error" then
		logEntry.TextColor3 = CONFIG.Colors.Error
		logEntry.Text = "<b>" .. messageStr .. "</b>"
	elseif messageType == "Warning" then
		logEntry.TextColor3 = CONFIG.Colors.Warning
		logEntry.Text = "<b>" .. messageStr .. "</b>"
	elseif messageType == "Input" then
		logEntry.TextColor3 = CONFIG.Colors.InputEcho
		logEntry.Text = "> " .. messageStr
	elseif messageType == "Info" then
		logEntry.TextColor3 = CONFIG.Colors.Info
		logEntry.Text = messageStr
	else
		logEntry.TextColor3 = CONFIG.Colors.Text
		logEntry.Text = messageStr
	end

	-- Asynchronously swap in a Google-translated version (🌐 marks translated
	-- lines; tapping a translated line toggles back to the original text).
	-- Skips code echoes and bulk history loads.
	local originalLogText = logEntry.Text
	local translatedLogText = nil
	local showingTranslation = false

	if uiSettings.autoTranslate and not bulkLoad and messageType ~= "Input" and #messageStr > 1 then
		queueTranslation(messageStr, languages[currentLanguageIndex].Code, function(translated)
			if translated and translated ~= messageStr and logFrame.Parent then
				local safe = escapeRichText(translated)
				if messageType == "Error" or messageType == "Warning" then
					translatedLogText = "<b>🌐 " .. safe .. "</b>"
				else
					translatedLogText = "🌐 " .. safe
				end
				showingTranslation = true
				logEntry.Text = translatedLogText
			end
		end)
	end

	table.insert(
		connections,
		logEntry.InputBegan:Connect(function(input)
			if not translatedLogText then
				return
			end
			if
				input.UserInputType ~= Enum.UserInputType.MouseButton1
				and input.UserInputType ~= Enum.UserInputType.Touch
			then
				return
			end
			-- Only toggle on a genuine tap, not a scroll drag
			local startPos = input.Position
			local changedConn
			changedConn = input.Changed:Connect(function()
				if input.UserInputState == Enum.UserInputState.End then
					changedConn:Disconnect()
					if (input.Position - startPos).Magnitude < 10 then
						showingTranslation = not showingTranslation
						logEntry.Text = showingTranslation and translatedLogText or originalLogText
					end
				end
			end)
		end)
	)

	local actionsFrame = logFrame.Actions
	table.insert(
		connections,
		actionsFrame.CopyBtn.MouseButton1Click:Connect(function()
			local textToCopy = (messageType == "Input") and "> " .. messageStr or messageStr
			local success, err = pcall(function()
				setclipboard(textToCopy)
			end)
			if success then
				log("Copied to clipboard.", "Output")
			else
				log("Clipboard write failed: " .. tostring(err), "Error")
			end
		end)
	)

	table.insert(
		connections,
		actionsFrame.DelBtn.MouseButton1Click:Connect(function()
			createClickParticles(logFrame, CONFIG.Colors.Error)
			local tween =
				TweenService:Create(logFrame, TweenInfo.new(0.3), { Size = UDim2.new(1, 0, 0, 0), Transparency = 1 })
			tween:Play()
			tween.Completed:Wait()
			if logFrame.Parent then
				logFrame:Destroy()
			end

			local idx = table.find(activeLogFrames, logFrame)
			if idx then
				table.remove(activeLogFrames, idx)
			end
			requestCanvasUpdate()
		end)
	)

	table.insert(
		connections,
		logFrame.MouseEnter:Connect(function()
			actionsFrame.Visible = true
		end)
	)
	table.insert(
		connections,
		logFrame.MouseLeave:Connect(function()
			actionsFrame.Visible = false
		end)
	)

	logFrame.Visible = logMatchesFilter(logFrame)
	logFrame.Parent = logContainer
	table.insert(activeLogFrames, logFrame)

	if #activeLogFrames > CONFIG.MaxLogs then
		local oldest = table.remove(activeLogFrames, 1)
		if oldest and oldest.Parent then
			oldest:Destroy()
		end
	end

	if not bulkLoad then
		logFrame.Position = UDim2.new(0, 0, 0, 24)
		logEntry.TextTransparency = 1
		local entranceInfo = TweenInfo.new(0.35, Enum.EasingStyle.Quint, Enum.EasingDirection.Out)
		TweenService:Create(logFrame, entranceInfo, { Position = UDim2.new(0, 0, 0, 0) }):Play()
		TweenService:Create(logEntry, entranceInfo, { TextTransparency = 0 }):Play()
		requestCanvasUpdate()
		scrollLogsToBottom()
	end

	isLoggingInternally = false
end

local function refreshLogs()
	clearLogs()
	if not isExecuteScriptEnabled then
		log(
			"Warning: No executor found ('execute_script' or 'loadstring'). Code execution will not work.",
			"Warning",
			true
		)
	elseif executorType == "loadstring" then
		log("Note: 'execute_script' not found; falling back to the executor's default 'loadstring'.", "Info", true)
	end

	local history = LogService:GetLogHistory()
	for _, entry in ipairs(history) do
		local typeStr = "Output"
		if entry.messageType == Enum.MessageType.MessageWarning then
			typeStr = "Warning"
		elseif entry.messageType == Enum.MessageType.MessageError then
			typeStr = "Error"
		elseif entry.messageType == Enum.MessageType.MessageInfo then
			typeStr = "Info"
		end
		log(entry.message, typeStr, true)
	end
	log("Console logs refreshed. Type 'tutorial()' to see the intro again.", "Info", true)
	requestCanvasUpdate()
	scrollLogsToBottom()
end

local function executeCommand()
	local command = inputBox.Text
	if command:gsub("%s", "") == "" then
		return
	end

	createClickParticles(runButton, CONFIG.Colors.Text)
	table.insert(commandHistory, 1, command)
	if #commandHistory > 50 then
		table.remove(commandHistory)
	end
	historyIndex = 0

	if command:lower():gsub("%s", "") == "tutorial()" then
		showTutorial()
		return
	end

	if not isExecuteScriptEnabled then
		log("Execution failed: no executor available (missing 'execute_script' and 'loadstring').", "Error")
		return
	end

	-- Run on a separate thread so a long-running or yielding script never
	-- freezes the console's input handler.
	task.spawn(function()
		local success, err = pcall(executeScript, command)
		if not success then
			log("Runtime Error: " .. tostring(err), "Error")
		end
	end)
end

-- === Mobile typing mode ===
-- While the code editor is focused on a touch device, the whole input row
-- moves to the top of the window (right under the header) where the
-- on-screen keyboard can never cover it; logs re-flow underneath. In the
-- full-screen editor, the editing area shrinks into the top half instead.
local isTypingMode = false

local function enterTypingMode()
	if isTypingMode or isMinimized then
		return
	end
	isTypingMode = true
	local tweenInfo = TweenInfo.new(0.25, Enum.EasingStyle.Quint, Enum.EasingDirection.Out)
	if isInputMaximized then
		-- Shrink the editing area into the upper half so the keyboard clears it
		TweenService:Create(inputContainer, tweenInfo, {
			Position = UDim2.new(0.5, 0, 0, 72),
			Size = UDim2.new(1, -10, 0.5, -40),
		}):Play()
	else
		-- Slide the whole footer (tabs + editor) to just below the header
		filterBar.Visible = false
		TweenService:Create(footer, tweenInfo, { Position = UDim2.new(0, 0, 0, 42) }):Play()
		TweenService:Create(logContainer, tweenInfo, {
			Position = UDim2.new(0, 0, 0, 42 + FOOTER_H + 6),
			Size = UDim2.new(1, 0, 1, -(42 + FOOTER_H + 6)),
		}):Play()
	end
end

local function exitTypingMode()
	if not isTypingMode then
		return
	end
	isTypingMode = false
	local tweenInfo = TweenInfo.new(0.25, Enum.EasingStyle.Quint, Enum.EasingDirection.Out)
	if isInputMaximized then
		TweenService:Create(inputContainer, tweenInfo, {
			Position = UDim2.new(0.5, 0, 0, 72),
			Size = UDim2.new(1, -10, 1, -78),
		}):Play()
	else
		filterBar.Visible = not isMinimized
		TweenService:Create(footer, tweenInfo, { Position = UDim2.new(0, 0, 1, -FOOTER_H) }):Play()
		TweenService:Create(logContainer, tweenInfo, {
			Position = UDim2.new(0, 0, 0, 72),
			Size = UDim2.new(1, 0, 1, -72 - FOOTER_H),
		}):Play()
	end
end

