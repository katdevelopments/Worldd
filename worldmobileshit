-- Clipboard reading is executor-specific; try the known getter names.
local function readClipboard()
	local getter = (type(getclipboard) == "function" and getclipboard)
		or (type(get_clipboard) == "function" and get_clipboard)
		or (type(getrbxclipboard) == "function" and getrbxclipboard)
	if not getter then
		return nil, "unsupported"
	end
	local ok, result = pcall(getter)
	if ok and type(result) == "string" then
		return result
	end
	return nil, "failed"
end

