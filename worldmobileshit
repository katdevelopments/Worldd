-- Resolve an execution backend. Prefer the environment's custom
-- execute_script (if one was injected into getgenv), otherwise fall back to
-- the executor's normal execute path via loadstring.
local executeScript = nil
local executorType = nil

pcall(function()
    if getgenv and getgenv().execute_script then
        executeScript = getgenv().execute_script
        executorType = "execute_script"
    end
end)

if not executeScript then
    pcall(function()
        if loadstring then
            executeScript = function(source)
                local fn, compileErr = loadstring(source)
                if not fn then
                    error(compileErr, 0)
                end
                return fn()
            end
            executorType = "loadstring"
        end
    end)
end

