-- === FPS booster & Anti-AFK ===
local applyFpsBooster, applyAntiAfk
do
	local Lighting = game:GetService("Lighting")
	local fpsConnection
	local antiAfkConnection

	local function stripForFps(inst)
		pcall(function()
			if
				inst:IsA("ParticleEmitter")
				or inst:IsA("Trail")
				or inst:IsA("Smoke")
				or inst:IsA("Fire")
				or inst:IsA("Sparkles")
				or inst:IsA("Explosion")
			then
				inst.Enabled = false
			elseif inst:IsA("Texture") or inst:IsA("Decal") then
				inst.Transparency = 1
			elseif inst:IsA("MeshPart") or inst:IsA("BasePart") then
				inst.Material = Enum.Material.Plastic
				inst.Reflectance = 0
				if inst:IsA("MeshPart") then
					inst.RenderFidelity = Enum.RenderFidelity.Performance
				end
			end
		end)
	end

	function applyFpsBooster(on)
		if on then
			pcall(function()
				Lighting.GlobalShadows = false
				Lighting.FogEnd = 9e9
				Lighting.Brightness = 1
				if sethiddenproperty then
					sethiddenproperty(Lighting, "Technology", 1)
				end
				local terrain = workspace:FindFirstChildOfClass("Terrain")
				if terrain then
					terrain.WaterWaveSize = 0
					terrain.WaterWaveSpeed = 0
					terrain.WaterReflectance = 0
					terrain.WaterTransparency = 0
				end
			end)
			pcall(function()
				if setfpscap then
					setfpscap(0)
				end
			end)
			for _, inst in ipairs(workspace:GetDescendants()) do
				stripForFps(inst)
			end
			if fpsConnection then
				fpsConnection:Disconnect()
			end
			fpsConnection = workspace.DescendantAdded:Connect(stripForFps)
			table.insert(connections, fpsConnection)
			log("FPS Booster enabled. (Stripped effects/textures; some visuals won't restore until rejoin.)", "Info")
		else
			if fpsConnection then
				fpsConnection:Disconnect()
				fpsConnection = nil
			end
			log("FPS Booster disabled. Rejoin to fully restore stripped visuals.", "Info")
		end
	end

	function applyAntiAfk(on)
		if on then
			if antiAfkConnection then
				antiAfkConnection:Disconnect()
			end
			local ok = pcall(function()
				local VirtualUser = game:GetService("VirtualUser")
				antiAfkConnection = player.Idled:Connect(function()
					pcall(function()
						VirtualUser:CaptureController()
						VirtualUser:ClickButton2(Vector2.new())
					end)
				end)
			end)
			if ok and antiAfkConnection then
				table.insert(connections, antiAfkConnection)
				log("Anti-AFK enabled. You won't be kicked for being idle.", "Info")
			else
				log("Anti-AFK could not hook the idle signal in this environment.", "Warning")
			end
		else
			if antiAfkConnection then
				antiAfkConnection:Disconnect()
				antiAfkConnection = nil
			end
			log("Anti-AFK disabled.", "Info")
		end
	end
end

