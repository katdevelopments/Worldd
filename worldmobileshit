-- === Startup intro ===
-- The globe pops in center-screen inside an orbital ring, real boot status
-- types out beneath it, then it arcs up into the minimized bubble with a
-- ripple + pop landing. Tap anywhere to skip.
local function playIntro()
    task.spawn(function()
        local finished = false
        local skipped = false

        mainFrame.Visible = false
        blurFrame.Visible = false

        local overlay = Instance.new("TextButton", screenGui)
        overlay.Name = "IntroOverlay"
        overlay.Size = UDim2.new(1, 0, 1, 0)
        overlay.BackgroundColor3 = Color3.new(0, 0, 0)
        overlay.BackgroundTransparency = 1
        overlay.Text = ""
        overlay.AutoButtonColor = false
        overlay.ZIndex = 40

        local ring = Instance.new("Frame", screenGui)
        ring.Name = "IntroRing"
        ring.AnchorPoint = Vector2.new(0.5, 0.5)
        ring.Position = UDim2.new(0.5, 0, 0.5, 0)
        ring.Size = UDim2.new(0, 132, 0, 132)
        ring.BackgroundTransparency = 1
        ring.ZIndex = 41
        Instance.new("UICorner", ring).CornerRadius = UDim.new(1, 0)
        local ringStroke = Instance.new("UIStroke", ring)
        ringStroke.Color = CONFIG.Colors.PrimaryAccent
        ringStroke.Thickness = 2
        ringStroke.Transparency = 1
        local ringGradient = Instance.new("UIGradient", ringStroke)
        ringGradient.Color = ColorSequence.new({
            ColorSequenceKeypoint.new(0, CONFIG.Colors.PrimaryAccent),
            ColorSequenceKeypoint.new(0.5, CONFIG.Colors.SecondaryAccent),
            ColorSequenceKeypoint.new(1, CONFIG.Colors.PrimaryAccent),
        })
        local ringScale = Instance.new("UIScale", ring)
        ringScale.Scale = 0.4

        local introIcon = Instance.new("ImageLabel", screenGui)
        introIcon.Name = "IntroIcon"
        introIcon.AnchorPoint = Vector2.new(0.5, 0.5)
        introIcon.Position = UDim2.new(0.5, 0, 0.5, 0)
        introIcon.Size = UDim2.new(0, 96, 0, 96)
        introIcon.BackgroundTransparency = 1
        introIcon.Image = CONFIG.IconID
        introIcon.ZIndex = 42
        local introScale = Instance.new("UIScale", introIcon)
        introScale.Scale = 0

        local introTitle = Instance.new("TextLabel", screenGui)
        introTitle.AnchorPoint = Vector2.new(0.5, 0)
        introTitle.Position = UDim2.new(0.5, 0, 0.5, 80)
        introTitle.Size = UDim2.new(0, 400, 0, 30)
        introTitle.BackgroundTransparency = 1
        introTitle.Font = CONFIG.BoldFont
        introTitle.Text = CONFIG.Title
        introTitle.TextColor3 = CONFIG.Colors.Text
        introTitle.TextSize = 24
        introTitle.TextTransparency = 1
        introTitle.ZIndex = 41

        local bootLabel = Instance.new("TextLabel", screenGui)
        bootLabel.AnchorPoint = Vector2.new(0.5, 0)
        bootLabel.Position = UDim2.new(0.5, 0, 0.5, 118)
        bootLabel.Size = UDim2.new(0, 420, 0, 62)
        bootLabel.BackgroundTransparency = 1
        bootLabel.Font = Enum.Font.Code
        bootLabel.Text = ""
        bootLabel.TextColor3 = CONFIG.Colors.InputEcho
        bootLabel.TextSize = 14
        bootLabel.TextTransparency = 0.15
        bootLabel.ZIndex = 41

        local introPieces = { overlay, ring, introIcon, introTitle, bootLabel }

        local function finish()
            if finished then return end
            finished = true
            for _, piece in ipairs(introPieces) do
                if piece.Parent then piece:Destroy() end
            end
            mainFrame.Visible = true
            blurFrame.Visible = true

            local popScale = Instance.new("UIScale", mainFrame)
            popScale.Scale = 1.25
            local popTween = TweenService:Create(popScale, TweenInfo.new(0.45, Enum.EasingStyle.Back, Enum.EasingDirection.Out), {Scale = 1})
            popTween:Play()
            popTween.Completed:Once(function() popScale:Destroy() end)

            local vp = workspace.CurrentCamera.ViewportSize
            local ripple = Instance.new("Frame", screenGui)
            ripple.AnchorPoint = Vector2.new(0.5, 0.5)
            ripple.Position = UDim2.fromOffset(vp.X * 0.5, vp.Y * 0.05 + 30)
            ripple.Size = UDim2.new(0, 56, 0, 56)
            ripple.BackgroundTransparency = 1
            ripple.ZIndex = 39
            Instance.new("UICorner", ripple).CornerRadius = UDim.new(1, 0)
            local rippleStroke = Instance.new("UIStroke", ripple)
            rippleStroke.Color = CONFIG.Colors.SecondaryAccent
            rippleStroke.Thickness = 3
            TweenService:Create(ripple, TweenInfo.new(0.6, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {Size = UDim2.new(0, 150, 0, 150)}):Play()
            TweenService:Create(rippleStroke, TweenInfo.new(0.6), {Transparency = 1, Thickness = 0.5}):Play()
            task.delay(0.7, function() if ripple.Parent then ripple:Destroy() end end)
        end

        table.insert(connections, overlay.MouseButton1Click:Connect(function() skipped = true end))

        -- Phase 1: reveal - globe pops in, ring blooms, gradient orbits
        TweenService:Create(overlay, TweenInfo.new(0.4), {BackgroundTransparency = 0.35}):Play()
        TweenService:Create(introScale, TweenInfo.new(0.55, Enum.EasingStyle.Back, Enum.EasingDirection.Out), {Scale = 1}):Play()
        TweenService:Create(ringScale, TweenInfo.new(0.6, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {Scale = 1}):Play()
        TweenService:Create(ringStroke, TweenInfo.new(0.6), {Transparency = 0.25}):Play()
        TweenService:Create(introTitle, TweenInfo.new(0.5), {TextTransparency = 0}):Play()
        local orbit = TweenService:Create(ringGradient, TweenInfo.new(3, Enum.EasingStyle.Linear, Enum.EasingDirection.Out, -1), {Rotation = 360})
        orbit:Play()
        local sway = TweenService:Create(introIcon, TweenInfo.new(1.6, Enum.EasingStyle.Sine, Enum.EasingDirection.InOut, -1, true), {Rotation = 8})
        sway:Play()
        createClickParticles(introIcon, CONFIG.Colors.SecondaryAccent)

        task.wait(0.55)

        -- Phase 2: boot lines - real status, typed out
        local bootLines = {
            "> hooking executor... " .. (executorType and ("OK [" .. executorType .. "]") or "FAILED (not found)"),
            "> loading settings... OK [" .. themes[currentThemeIndex].Name .. " / " .. languages[currentLanguageIndex].Name .. "]",
            "> world client ready.",
        }
        local shown = ""
        for _, line in ipairs(bootLines) do
            if skipped then break end
            for i = 1, #line do
                if skipped then break end
                bootLabel.Text = shown .. line:sub(1, i)
                task.wait(0.012)
            end
            shown = shown .. line .. "\n"
            bootLabel.Text = shown
            if not skipped then task.wait(0.25) end
        end
        if not skipped then task.wait(0.6) end

        if skipped then
            orbit:Cancel()
            sway:Cancel()
            finish()
            return
        end

        -- Phase 3: arc flight to the dock
        sway:Cancel()
        TweenService:Create(introIcon, TweenInfo.new(0.3), {Rotation = 0}):Play()
        TweenService:Create(introTitle, TweenInfo.new(0.3), {TextTransparency = 1}):Play()
        TweenService:Create(bootLabel, TweenInfo.new(0.3), {TextTransparency = 1}):Play()
        TweenService:Create(ringStroke, TweenInfo.new(0.3), {Transparency = 1}):Play()
        TweenService:Create(ringScale, TweenInfo.new(0.3, Enum.EasingStyle.Back, Enum.EasingDirection.In), {Scale = 0.2}):Play()
        TweenService:Create(overlay, TweenInfo.new(0.6), {BackgroundTransparency = 1}):Play()

        local vp = workspace.CurrentCamera.ViewportSize
        local startPoint = Vector2.new(vp.X * 0.5, vp.Y * 0.5)
        local endPoint = Vector2.new(vp.X * 0.5, vp.Y * 0.05 + 30)
        local controlPoint = Vector2.new(vp.X * 0.66, vp.Y * 0.26)

        local duration = 0.85
        local elapsed = 0
        while elapsed < duration and not skipped do
            elapsed += task.wait()
            local t = math.clamp(elapsed / duration, 0, 1)
            local eased = TweenService:GetValue(t, Enum.EasingStyle.Quad, Enum.EasingDirection.InOut)
            local inv = 1 - eased
            local pos = startPoint * (inv * inv) + controlPoint * (2 * inv * eased) + endPoint * (eased * eased)
            introIcon.Position = UDim2.fromOffset(pos.X, pos.Y)
            local size = 96 - (96 - 36) * eased
            introIcon.Size = UDim2.fromOffset(size, size)
            introIcon.Rotation = 360 * eased
        end

        orbit:Cancel()
        finish()
    end)
end

