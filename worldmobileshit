local function applyPickerFilter()
    local query = pickerSearch.Text:lower()
    for _, opt in ipairs(currentPickerButtons) do
        if opt.Parent then
            local name = (opt:GetAttribute("OptionName") or ""):lower()
            opt.Visible = (query == "") or (name:find(query, 1, true) ~= nil)
        end
    end
    pickerScroll.CanvasPosition = Vector2.new(0, 0)
end

local function closePicker(instant)
    if not pickerFrame.Visible then return end
    isPickerOpen = false
    if instant then
        pickerFrame.Visible = false
        pickerScale.Scale = 0
    else
        local tw = TweenService:Create(pickerScale, TweenInfo.new(0.2, Enum.EasingStyle.Quad, Enum.EasingDirection.In), {Scale = 0})
        tw:Play()
        tw.Completed:Once(function() pickerFrame.Visible = false end)
    end
end

-- entries: array of {Name, Font?, SwatchA?, SwatchB?} — Font renders the
-- option in its own typeface (font picker), the swatches draw a theme
-- preview dot (theme picker).
local function openPicker(title, entries, currentIndex, onPick, searchable)
    pickerTitle.Text = title
    for _, child in ipairs(pickerScroll:GetChildren()) do
        if child:IsA("TextButton") then child:Destroy() end
    end
    table.clear(currentPickerButtons)

    pickerSearch.Text = ""
    pickerSearch.Visible = searchable == true
    if searchable then
        pickerScroll.Position = UDim2.new(0, 10, 0, 78)
        pickerScroll.Size = UDim2.new(1, -20, 1, -88)
    else
        pickerScroll.Position = UDim2.new(0, 10, 0, 40)
        pickerScroll.Size = UDim2.new(1, -20, 1, -50)
    end

    for i, entry in ipairs(entries) do
        local opt = Instance.new("TextButton", pickerScroll)
        opt.Size = UDim2.new(1, -6, 0, 34)
        opt.LayoutOrder = i
        local selected = (i == currentIndex)
        opt.BackgroundColor3 = selected and CONFIG.Colors.SecondaryAccent or CONFIG.Colors.UtilButton
        opt.Font = entry.Font or CONFIG.Font
        opt.Text = (selected and "✓  " or "") .. entry.Name
        opt.TextColor3 = selected and Color3.new(1, 1, 1) or CONFIG.Colors.Text
        opt.TextSize = 15
        opt.ZIndex = 13
        Instance.new("UICorner", opt).CornerRadius = UDim.new(0, 6)
        addDepthGradient(opt)
        safeSetCursor(opt, "rbxasset://SystemCursor/Arrow")
        opt:SetAttribute("OptionName", entry.Name)
        table.insert(currentPickerButtons, opt)
        if entry.SwatchA then
            local sw = Instance.new("Frame", opt)
            sw.Size = UDim2.new(0, 16, 0, 16)
            sw.Position = UDim2.new(1, -14, 0.5, 0)
            sw.AnchorPoint = Vector2.new(1, 0.5)
            sw.BackgroundColor3 = entry.SwatchA
            sw.ZIndex = 14
            Instance.new("UICorner", sw).CornerRadius = UDim.new(1, 0)
            local swStroke = Instance.new("UIStroke", sw)
            swStroke.Color = entry.SwatchB
            swStroke.Thickness = 2
        end
        opt.MouseButton1Click:Connect(function()
            createClickParticles(opt)
            onPick(i)
            closePicker()
        end)
    end
    pickerScroll.CanvasPosition = Vector2.new(0, 0)
    pickerFrame.Visible = true
    isPickerOpen = true
    pickerScale.Scale = 0
    TweenService:Create(pickerScale, TweenInfo.new(0.25, Enum.EasingStyle.Back, Enum.EasingDirection.Out), {Scale = 1}):Play()
end

table.insert(connections, pickerClose.MouseButton1Click:Connect(function() closePicker() end))
