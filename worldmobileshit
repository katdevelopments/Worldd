local function loadSettings()
	local ok, data = pcall(function()
		return HttpService:JSONDecode(readfile(SETTINGS_FILE))
	end)
	if not ok or type(data) ~= "table" then
		return
	end
	if type(data.themeIndex) == "number" and themes[data.themeIndex] then
		currentThemeIndex = data.themeIndex
	end
	if type(data.fontIndex) == "number" and fontsList[data.fontIndex] then
		currentFontIndex = data.fontIndex
	end
	if type(data.textSizeIndex) == "number" and textSizes[data.textSizeIndex] then
		currentTextSizeIndex = data.textSizeIndex
	end
	if type(data.languageCode) == "string" then
		for i, lang in ipairs(languages) do
			if lang.Code == data.languageCode then
				currentLanguageIndex = i
				break
			end
		end
	end
	if type(data.particles) == "boolean" then
		uiSettings.particles = data.particles
	end
	if type(data.glow) == "boolean" then
		uiSettings.glow = data.glow
	end
	if type(data.blur) == "boolean" then
		uiSettings.blur = data.blur
	end
	if type(data.autoTranslate) == "boolean" then
		uiSettings.autoTranslate = data.autoTranslate
	end
	if type(data.autoScroll) == "boolean" then
		uiSettings.autoScroll = data.autoScroll
	end
	if type(data.fpsBooster) == "boolean" then
		uiSettings.fpsBooster = data.fpsBooster
	end
	if type(data.antiAfk) == "boolean" then
		uiSettings.antiAfk = data.antiAfk
	end
	if type(data.editorWordWrap) == "boolean" then
		uiSettings.editorWordWrap = data.editorWordWrap
	end
	if type(data.consoleWordWrap) == "boolean" then
		uiSettings.consoleWordWrap = data.consoleWordWrap
	end
	if type(data.editorLineNumbers) == "boolean" then
		uiSettings.editorLineNumbers = data.editorLineNumbers
	end
	if type(data.consoleLineNumbers) == "boolean" then
		uiSettings.consoleLineNumbers = data.consoleLineNumbers
	end
	if type(data.customTheme) == "table" then
		for key, v in pairs(data.customTheme) do
			if
				customThemeColors[key]
				and type(v) == "table"
				and type(v.r) == "number"
				and type(v.g) == "number"
				and type(v.b) == "number"
			then
				customThemeColors[key] =
					Color3.fromRGB(math.clamp(v.r, 0, 255), math.clamp(v.g, 0, 255), math.clamp(v.b, 0, 255))
			end
		end
	end
end

