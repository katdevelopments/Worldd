-- === Luau syntax highlighting ===
-- A RichText layer over the input box shows colorized code whenever the box
-- is not focused; while typing, the plain text (and its caret) is shown, so
-- the native caret always works.
local refreshInputHighlight

do
	local KEYWORDS = {}
	for _, kw in ipairs({
		"and",
		"break",
		"continue",
		"do",
		"else",
		"elseif",
		"end",
		"false",
		"for",
		"function",
		"if",
		"in",
		"local",
		"nil",
		"not",
		"or",
		"repeat",
		"return",
		"then",
		"true",
		"until",
		"while",
		"self",
		"export",
		"type",
	}) do
		KEYWORDS[kw] = true
	end

	local BUILTINS = {}
	for _, name in ipairs({
		"game",
		"workspace",
		"script",
		"math",
		"string",
		"table",
		"task",
		"os",
		"print",
		"warn",
		"error",
		"assert",
		"pcall",
		"xpcall",
		"select",
		"pairs",
		"ipairs",
		"next",
		"require",
		"tostring",
		"tonumber",
		"typeof",
		"unpack",
		"Instance",
		"Vector2",
		"Vector3",
		"CFrame",
		"Color3",
		"UDim",
		"UDim2",
		"Enum",
		"tick",
		"wait",
		"spawn",
		"delay",
		"getgenv",
		"setclipboard",
		"loadstring",
	}) do
		BUILTINS[name] = true
	end

	local highlightLabel = Instance.new("TextLabel", inputContainer)
	highlightLabel.Name = "HighlightLayer"
	highlightLabel.BackgroundTransparency = 1
	highlightLabel.Size = inputBox.Size
	highlightLabel.Position = UDim2.new(0, 0, 0, 0)
	highlightLabel.Font = CONFIG.Font
	highlightLabel.TextColor3 = CONFIG.Colors.Text
	highlightLabel.TextSize = CONFIG.TextSize
	highlightLabel.TextWrapped = uiSettings.editorWordWrap == true
	highlightLabel.TextXAlignment = Enum.TextXAlignment.Left
	highlightLabel.TextYAlignment = Enum.TextYAlignment.Top
	highlightLabel.RichText = true
	highlightLabel.Visible = false
	highlightLabel.ZIndex = 2
	local hlPad = Instance.new("UIPadding", highlightLabel)
	hlPad.PaddingLeft = UDim.new(0, uiSettings.editorLineNumbers == true and 32 or 10)
	hlPad.PaddingRight = UDim.new(0, 10)
	hlPad.PaddingTop = UDim.new(0, 5)
	hlPad.PaddingBottom = UDim.new(0, 5)

	table.insert(
		connections,
		inputBox:GetPropertyChangedSignal("Size"):Connect(function()
			highlightLabel.Size = inputBox.Size
		end)
	)

	local function toHex(c)
		return string.format(
			"#%02X%02X%02X",
			math.floor(c.R * 255 + 0.5),
			math.floor(c.G * 255 + 0.5),
			math.floor(c.B * 255 + 0.5)
		)
	end

	local function colorize(src)
		local kwColor = toHex(CONFIG.Colors.SecondaryAccent)
		local strColor = toHex(CONFIG.Colors.Warning)
		local numColor = toHex(CONFIG.Colors.Info)
		local cmtColor = toHex(CONFIG.Colors.InputEcho)
		local builtinColor = toHex(CONFIG.Colors.PrimaryAccent)

		local out = {}
		local i, n = 1, #src
		local function push(text, color)
			local esc = text:gsub("&", "&amp;"):gsub("<", "&lt;"):gsub(">", "&gt;")
			if color then
				table.insert(out, '<font color="' .. color .. '">' .. esc .. "</font>")
			else
				table.insert(out, esc)
			end
		end

		-- Built by concatenation so this file's own source never contains a
		-- long-bracket sequence: loaders that wrap the script inside a
		-- long-bracket string would be terminated early by a raw one.
		local LONG_OPEN = "[" .. "["
		local LONG_CLOSE = "]" .. "]"

		while i <= n do
			local two = src:sub(i, i + 1)
			local c = src:sub(i, i)
			if two == "--" then
				local j
				if src:sub(i + 2, i + 3) == LONG_OPEN then
					local close = src:find(LONG_CLOSE, i + 4, true)
					j = close and (close + 1) or n
				else
					local nl = src:find("\n", i, true)
					j = nl and (nl - 1) or n
				end
				push(src:sub(i, j), cmtColor)
				i = j + 1
			elseif c == '"' or c == "'" then
				local j = i + 1
				while j <= n do
					local ch = src:sub(j, j)
					if ch == "\\" then
						j += 2
					elseif ch == c or ch == "\n" then
						break
					else
						j += 1
					end
				end
				if j > n then
					j = n
				end
				push(src:sub(i, j), strColor)
				i = j + 1
			elseif two == LONG_OPEN then
				local close = src:find(LONG_CLOSE, i + 2, true)
				local j = close and (close + 1) or n
				push(src:sub(i, j), strColor)
				i = j + 1
			elseif c:match("%d") then
				local j = i
				while j < n and src:sub(j + 1, j + 1):match("[%dxXeE%.%_abcdefABCDEF]") do
					j += 1
				end
				push(src:sub(i, j), numColor)
				i = j + 1
			elseif c:match("[%a_]") then
				local j = i
				while j < n and src:sub(j + 1, j + 1):match("[%w_]") do
					j += 1
				end
				local word = src:sub(i, j)
				if KEYWORDS[word] then
					push(word, kwColor)
				elseif BUILTINS[word] then
					push(word, builtinColor)
				else
					push(word)
				end
				i = j + 1
			else
				local j = i
				while j < n do
					local nc = src:sub(j + 1, j + 1)
					if nc:match("[%w_\"'%-%[]") then
						break
					end
					j += 1
				end
				push(src:sub(i, j))
				i = j + 1
			end
		end
		return table.concat(out)
	end

	function refreshInputHighlight()
		if inputBox:IsFocused() or inputBox.Text == "" then
			highlightLabel.Visible = false
			inputBox.TextTransparency = 0
		else
			highlightLabel.Font = CONFIG.Font
			highlightLabel.TextSize = CONFIG.TextSize
			highlightLabel.TextColor3 = CONFIG.Colors.Text
			highlightLabel.Text = colorize(inputBox.Text)
			highlightLabel.Visible = true
			inputBox.TextTransparency = 1
		end
	end

	table.insert(connections, inputBox.Focused:Connect(refreshInputHighlight))
	table.insert(connections, inputBox.FocusLost:Connect(refreshInputHighlight))
	table.insert(
		connections,
		inputBox:GetPropertyChangedSignal("Text"):Connect(function()
			if not inputBox:IsFocused() then
				task.defer(refreshInputHighlight)
			end
		end)
	)
end

