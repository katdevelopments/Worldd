-- === Settings persistence (survives rejoins on executors with file APIs) ===
local SETTINGS_FILE = "WorldClient_Settings.json"

local function saveSettings()
    pcall(function()
        local customTheme = {}
        for key, color in pairs(customThemeColors) do
            customTheme[key] = {
                r = math.floor(color.R * 255 + 0.5),
                g = math.floor(color.G * 255 + 0.5),
                b = math.floor(color.B * 255 + 0.5),
            }
        end
        writefile(SETTINGS_FILE, HttpService:JSONEncode({
            themeIndex = currentThemeIndex,
            fontIndex = currentFontIndex,
            textSizeIndex = currentTextSizeIndex,
            languageCode = languages[currentLanguageIndex].Code,
            particles = uiSettings.particles,
            glow = uiSettings.glow,
            blur = uiSettings.blur,
            autoTranslate = uiSettings.autoTranslate,
            customTheme = customTheme,
        }))
    end)
end

local function loadSettings()
    local ok, data = pcall(function() return HttpService:JSONDecode(readfile(SETTINGS_FILE)) end)
    if not ok or type(data) ~= "table" then return end
    if type(data.themeIndex) == "number" and themes[data.themeIndex] then
        currentThemeIndex = data.themeIndex
    end
    if type(data.fontIndex) == "number" and fontsList[data.fontIndex] then
        currentFontIndex = data.fontIndex
    end
    if type(data.textSizeIndex) == "number" and textSizes[data.textSizeIndex] then
        currentTextSizeIndex = data.textSizeIndex
    end
    if type(data.languageCode) == "string" then
        for i, lang in ipairs(languages) do
            if lang.Code == data.languageCode then
                currentLanguageIndex = i
                break
            end
        end
    end
    if type(data.particles) == "boolean" then uiSettings.particles = data.particles end
    if type(data.glow) == "boolean" then uiSettings.glow = data.glow end
    if type(data.blur) == "boolean" then uiSettings.blur = data.blur end
    if type(data.autoTranslate) == "boolean" then uiSettings.autoTranslate = data.autoTranslate end
    if type(data.customTheme) == "table" then
        for key, v in pairs(data.customTheme) do
            if customThemeColors[key] and type(v) == "table"
                and type(v.r) == "number" and type(v.g) == "number" and type(v.b) == "number" then
                customThemeColors[key] = Color3.fromRGB(
                    math.clamp(v.r, 0, 255),
                    math.clamp(v.g, 0, 255),
                    math.clamp(v.b, 0, 255)
                )
            end
        end
    end
end

