    function logMatchesFilter(frame)
        local logType = frame:GetAttribute("LogType") or "Output"
        if activeFilter ~= "All" and logType ~= activeFilter then
            return false
        end
        if searchQuery ~= "" then
            local raw = (frame:GetAttribute("RawText") or ""):lower()
            if not raw:find(searchQuery, 1, true) then
                return false
            end
        end
        return true
    end

    local function applyLogFilter()
        for _, frame in ipairs(activeLogFrames) do
            if frame and frame.Parent then
                frame.Visible = logMatchesFilter(frame)
            end
        end
        task.defer(function()
            logContainer.CanvasSize = UDim2.new(0, 0, 0, uiListLayout.AbsoluteContentSize.Y)
        end)
    end

    local function updateChipVisuals()
        for filterValue, chip in pairs(chipButtons) do
