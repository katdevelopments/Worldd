    activeTweens.glowTransparency = TweenService:Create(blurStroke, pulseInfo, {Transparency = 0.9})
    activeTweens.glowThickness = TweenService:Create(blurStroke, pulseInfo, {Thickness = 6})
    activeTweens.strokeSpin = TweenService:Create(strokeGradient, spinInfo, {Rotation = 360})
    activeTweens.glowTransparency:Play()
    activeTweens.glowThickness:Play()
    activeTweens.strokeSpin:Play()
