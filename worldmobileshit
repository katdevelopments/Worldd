		prevButton.Visible = currentPage > 1
		nextButton.Text = (currentPage == #pages) and "✅" or "➡️"
		skipButton.Visible = (currentPage ~= #pages)

		-- Typewriter steps by codepoint so translated UTF-8 text never
		-- renders a half-cut character
		local bodyText = tr(pageData.Text)
		local charCount = utf8.len(bodyText) or #bodyText
		for i = 1, charCount do
			if not tutBody.Parent then
				break
			end
			local byteEnd = (utf8.offset(bodyText, i + 1) or (#bodyText + 1)) - 1
			tutBody.Text = string.sub(bodyText, 1, byteEnd)
