	function switchToTab(index, instant)
		if not editorTabs[index] then
			return
		end
		-- Save whatever is on screen back into the outgoing tab. Skipped for
		-- close operations (instant), where the outgoing text is being
		-- discarded and must not overwrite the newly-shown tab.
		if not instant and editorTabs[activeTabIndex] and not switchingTabs then
			editorTabs[activeTabIndex].content = inputBox.Text
		end
		activeTabIndex = index
		switchingTabs = true
		inputBox.Text = editorTabs[index].content
		switchingTabs = false
		if refreshInputHighlight then
			task.defer(refreshInputHighlight)
		end
		refreshTabBar()
		saveTabs()
	end

	local TAB_WIDTH = 106

	function refreshTabBar()
		for id, btn in pairs(tabButtons) do
			btn:Destroy()
			tabButtons[id] = nil
		end
		for i, tab in ipairs(editorTabs) do
			local isActive = (i == activeTabIndex)
			local btn = Instance.new("TextButton", tabBar)
			btn.Name = "Tab_" .. tab.id
			btn.Size = UDim2.new(0, TAB_WIDTH, 0, 26)
			btn.LayoutOrder = i
			btn.AutoButtonColor = false
			btn.BackgroundColor3 = isActive and CONFIG.Colors.SecondaryAccent or CONFIG.Colors.UtilButton
			btn.Font = isActive and CONFIG.BoldFont or CONFIG.Font
			btn.Text = (tab.pinned and "📌 " or "") .. tab.name
			btn.TextColor3 = isActive and Color3.new(1, 1, 1) or CONFIG.Colors.Text
			btn.TextSize = 13
			btn.TextTruncate = Enum.TextTruncate.AtEnd
			btn.TextXAlignment = Enum.TextXAlignment.Left
			btn.ZIndex = 5
			Instance.new("UICorner", btn).CornerRadius = UDim.new(0, 6)
			addDepthGradient(btn)
			safeSetCursor(btn, "rbxasset://SystemCursor/Arrow")
			local btnPad = Instance.new("UIPadding", btn)
			btnPad.PaddingLeft = UDim.new(0, 8)
			btnPad.PaddingRight = UDim.new(0, 22)

			local closeX = Instance.new("TextButton", btn)
			closeX.Size = UDim2.new(0, 18, 0, 18)
			closeX.Position = UDim2.new(1, -2, 0.5, 0)
			closeX.AnchorPoint = Vector2.new(1, 0.5)
			closeX.BackgroundTransparency = 1
			closeX.Font = Enum.Font.SourceSansBold
			closeX.Text = "✖"
			closeX.TextColor3 = isActive and Color3.new(1, 1, 1) or CONFIG.Colors.InputEcho
			closeX.TextSize = 14
			closeX.ZIndex = 6
			safeSetCursor(closeX, "rbxasset://SystemCursor/Arrow")
			closeX.MouseButton1Click:Connect(function()
				closeTab(tab)
			end)

			-- A UIScale used for the add-tab entrance pop and active bounce
			local sc = Instance.new("UIScale", btn)
			sc.Scale = 1
			if isActive then
				-- Small bounce on the tab that just became active
				sc.Scale = 0.9
				TweenService
					:Create(sc, TweenInfo.new(0.22, Enum.EasingStyle.Back, Enum.EasingDirection.Out), { Scale = 1 })
					:Play()
			end

			-- Tap = switch, drag = reorder, hold = context menu
			btn.InputBegan:Connect(function(input)
				if
					input.UserInputType ~= Enum.UserInputType.MouseButton1
					and input.UserInputType ~= Enum.UserInputType.Touch
				then
					return
				end
				local drag = {
					tab = tab,
					button = btn,
					pointerStart = UserInputService:GetMouseLocation().X,
					startTime = tick(),
					moved = false,
					consumed = false,
				}
				drag.holdTimer = task.delay(0.4, function()
					if activeDrag == drag and not drag.moved then
						drag.consumed = true
						openTabMenu(tab)
					end
				end)
				activeDrag = drag
				local endConn
				endConn = input.Changed:Connect(function()
					if input.UserInputState ~= Enum.UserInputState.End then
						return
					end
					endConn:Disconnect()
					if drag.holdTimer then
						task.cancel(drag.holdTimer)
						drag.holdTimer = nil
					end
					if activeDrag == drag then
						activeDrag = nil
					end
					btn.ZIndex = 5
					if drag.consumed then
						return
					end
					if not drag.moved and (tick() - drag.startTime) < 0.4 then
						local idx = table.find(editorTabs, tab)
						if idx then
							switchToTab(idx)
						end
					else
						relayoutTabs()
						saveTabs()
					end
				end)
			end)

			tabButtons[tab.id] = btn
		end
		tabBar.CanvasSize = UDim2.new(0, 0, 0, 0)
	end

	-- Live reorder while dragging
	table.insert(
		connections,
		RunService.RenderStepped:Connect(function()
			if not activeDrag then
				return
			end
			local pointerX = UserInputService:GetMouseLocation().X
			if math.abs(pointerX - activeDrag.pointerStart) > 8 then
				activeDrag.moved = true
				if activeDrag.holdTimer then
					task.cancel(activeDrag.holdTimer)
					activeDrag.holdTimer = nil
				end
			end
			if not activeDrag.moved then
				return
			end
			activeDrag.button.ZIndex = 8
			local dragIdx = table.find(editorTabs, activeDrag.tab)
			if not dragIdx then
				return
			end
			local activeTab = editorTabs[activeTabIndex]
			for i, tab in ipairs(editorTabs) do
				if i ~= dragIdx then
					local b = tabButtons[tab.id]
					if b then
						local mid = b.AbsolutePosition.X + b.AbsoluteSize.X * 0.5
						if (dragIdx < i and pointerX > mid) or (dragIdx > i and pointerX < mid) then
							table.remove(editorTabs, dragIdx)
							table.insert(editorTabs, i, activeDrag.tab)
							-- keep the active index pointing at the same tab object
							activeTabIndex = table.find(editorTabs, activeTab) or activeTabIndex
							relayoutTabs()
							break
						end
					end
				end
			end
		end)
	)

	function addTabFn()
		if editorTabs[activeTabIndex] then
			editorTabs[activeTabIndex].content = inputBox.Text
		end
		local tab = newTab("Script " .. (#editorTabs + 1), "", false)
		table.insert(editorTabs, tab)
		switchToTab(#editorTabs)
		task.defer(function()
			tabBar.CanvasPosition = Vector2.new(math.huge, 0)
		end)
	end

	function closeTab(tab)
		local idx = table.find(editorTabs, tab)
		if not idx then
			return
		end
		table.remove(editorTabs, idx)
		if #editorTabs == 0 then
			table.insert(editorTabs, newTab("Script 1", "", false))
		end
		if activeTabIndex >= idx then
			activeTabIndex = math.max(1, math.min(activeTabIndex - 1, #editorTabs))
		end
		if activeTabIndex < 1 then
			activeTabIndex = 1
		end
		switchToTab(activeTabIndex, true)
		refreshTabBar()
		saveTabs()
	end

	function closeAllTabs()
		for i = #editorTabs, 1, -1 do
			if not editorTabs[i].pinned then
				table.remove(editorTabs, i)
			end
		end
		if #editorTabs == 0 then
			table.insert(editorTabs, newTab("Script 1", "", false))
		end
		activeTabIndex = 1
		switchToTab(1, true)
		refreshTabBar()
		saveTabs()
	end

	table.insert(
		connections,
		addTabButton.MouseButton1Click:Connect(function()
			createClickParticles(addTabButton)
			addTabFn()
		end)
	)
	table.insert(
		connections,
		addTabButton.MouseEnter:Connect(function()
			TweenService:Create(addTabButton, TweenInfo.new(0.15), { BackgroundColor3 = CONFIG.Colors.UtilButtonHover })
