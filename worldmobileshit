    local switch = Instance.new("TextButton", row)
    switch.Size = UDim2.new(0, 46, 0, 24)
    switch.Position = UDim2.new(1, 0, 0.5, 0)
    switch.AnchorPoint = Vector2.new(1, 0.5)
    switch.Text = ""
    switch.ZIndex = 11
    Instance.new("UICorner", switch).CornerRadius = UDim.new(1, 0)
    safeSetCursor(switch, "rbxasset://SystemCursor/Arrow")

    local knob = Instance.new("Frame", switch)
    knob.Size = UDim2.new(0, 18, 0, 18)
    knob.AnchorPoint = Vector2.new(0, 0.5)
    knob.BackgroundColor3 = Color3.new(1, 1, 1)
    knob.ZIndex = 12
    Instance.new("UICorner", knob).CornerRadius = UDim.new(1, 0)

    local state = initial
    local function render(animate)
        local targetPos = state and UDim2.new(1, -21, 0.5, 0) or UDim2.new(0, 3, 0.5, 0)
        local targetColor = state and CONFIG.Colors.SecondaryAccent or CONFIG.Colors.UtilButton
        if animate then
            TweenService:Create(knob, TweenInfo.new(0.2, Enum.EasingStyle.Back, Enum.EasingDirection.Out), {Position = targetPos}):Play()
            TweenService:Create(switch, TweenInfo.new(0.2), {BackgroundColor3 = targetColor}):Play()
        else
            knob.Position = targetPos
            switch.BackgroundColor3 = targetColor
        end
    end
    render(false)
    registerLocalizedString(labelText)
    registerLocalizedRefresher(function() label.Text = tr(labelText) end)

    table.insert(themedUpdaters, function(theme, fontData)
        tintTween(label, {TextColor3 = theme.Text})
        label.Font = fontData.Font
        tintTween(switch, {BackgroundColor3 = state and theme.SecondaryAccent or theme.UtilButton})
    end)

    table.insert(connections, switch.MouseButton1Click:Connect(function()
        state = not state
        render(true)
        onChanged(state)
    end))
    return row
end

