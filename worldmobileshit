	local AUTOEXEC_FILE = "WorldClient_AutoExec.json"
	local autoExecScripts = {}

	pcall(function()
		local data = HttpService:JSONDecode(readfile(AUTOEXEC_FILE))
		if type(data) == "table" then
			for _, item in ipairs(data) do
				if type(item) == "table" and type(item.s) == "string" then
					table.insert(autoExecScripts, {
						Name = type(item.n) == "string" and item.n or "Script",
						Source = item.s,
						Enabled = item.e ~= false,
					})
				end
			end
		end
	end)

	local function saveAutoExecFile()
		pcall(function()
			local out = {}
			for _, item in ipairs(autoExecScripts) do
				table.insert(out, { n = item.Name, s = item.Source, e = item.Enabled })
			end
			writefile(AUTOEXEC_FILE, HttpService:JSONEncode(out))
		end)
	end

	function runAutoExecScripts()
		for _, item in ipairs(autoExecScripts) do
			if item.Enabled and item.Source:gsub("%s", "") ~= "" then
				if not isExecuteScriptEnabled then
					log("Auto-Execute skipped '" .. item.Name .. "': no executor available.", "Warning")
				else
