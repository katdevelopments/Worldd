	-- Auto-scroll is a master switch in Settings; scrolling up still
	-- temporarily suspends the follow until you return to the bottom.
	local followingBottom = uiSettings.autoScroll
	local suppressScrollDetect = false

	function scrollLogsToBottom(force)
		if not uiSettings.autoScroll and not force then
			return
		end
		if force then
			followingBottom = true
		end
		if not followingBottom then
			return
		end
		suppressScrollDetect = true
		task.defer(function()
			logContainer.CanvasPosition = Vector2.new(0, math.max(0, logContainer.AbsoluteCanvasSize.Y))
			task.delay(0.05, function()
				suppressScrollDetect = false
			end)
		end)
	end

	function setAutoScroll(on)
		uiSettings.autoScroll = on
		followingBottom = on
		if on then
			scrollLogsToBottom(true)
		end
	end

