	connections,
	clipboardRunButton.MouseButton1Click:Connect(function()
		local content, reason = readClipboard()
		if not content then
			if reason == "unsupported" then
				log(
					"Your executor does not expose a clipboard getter (getclipboard), so Run from Clipboard is unavailable. Paste into the editor instead.",
					"Warning"
				)
			else
				log("Could not read the clipboard.", "Error")
			end
			return
		end
		if content:gsub("%s", "") == "" then
			log("Clipboard is empty.", "Warning")
			return
		end
		-- Load into the editor (visible + highlighted) and run through the
		-- normal path so it lands in command history too.
		inputBox.Text = content
		log("Running script from clipboard (" .. #content .. " chars)...", "Info")
		executeCommand()
	end)
)

