    local function refreshText()
        btn.Text = tr(labelText) .. ":  " .. buildEntries()[getIndex()].Name .. "  ▼"
    end
    refreshText()
    registerLocalizedString(labelText)
    registerLocalizedRefresher(refreshText)

    table.insert(themedUpdaters, function(theme, fontData)
