local function debounce(func, delay)
    local timer
    return function(...)
        local context = self
        local args = {...}
        if timer then task.cancel(timer) end
        timer = task.delay(delay, function() func(context, unpack(args)) end)
    end
end

-- On Android/iOS the on-screen keyboard covers the bottom half of the screen
-- (and OnScreenKeyboardSize is not reliably reported in every executor), so
-- centered panels slide to the top of the screen while one of their text
-- boxes is focused, then glide back on unfocus.
local liftTweenInfo = TweenInfo.new(0.25, Enum.EasingStyle.Quint, Enum.EasingDirection.Out)
local function liftPanelWhileTyping(panel, textBox)
    table.insert(connections, textBox.Focused:Connect(function()
        if not UserInputService.TouchEnabled then return end
        panel:SetAttribute("LiftedForKeyboard", true)
        panel.AnchorPoint = Vector2.new(0.5, 0)
        TweenService:Create(panel, liftTweenInfo, {Position = UDim2.new(0.5, 0, 0, 12)}):Play()
    end))
    table.insert(connections, textBox.FocusLost:Connect(function()
        if not panel:GetAttribute("LiftedForKeyboard") then return end
        panel:SetAttribute("LiftedForKeyboard", false)
        panel.AnchorPoint = Vector2.new(0.5, 0.5)
        TweenService:Create(panel, liftTweenInfo, {Position = UDim2.new(0.5, 0, 0.5, 0)}):Play()
    end))
end

