-- === Google Translate integration ===
-- Works across executors: prefers the executor's request function, falls
-- back to game:HttpGet.
local function httpGet(url)
	local requester = (syn and syn.request)
		or (http and http.request)
		or http_request
		or (fluxus and fluxus.request)
		or request
	if requester then
		local ok, res = pcall(requester, { Url = url, Method = "GET" })
		if ok and type(res) == "table" and (res.StatusCode == 200 or res.Success) and type(res.Body) == "string" then
			return res.Body
		end
	end
	local ok, body = pcall(function()
		return game:HttpGet(url)
	end)
	if ok and type(body) == "string" then
		return body
	end
	return nil
end

local function escapeRichText(s)
	return (s:gsub("&", "&amp;"):gsub("<", "&lt;"):gsub(">", "&gt;"))
end

local log -- assigned further down; forward-declared so translation code can warn

-- Primary endpoint with a fallback for when gtx is rate-limited (HTTP 429)
-- or blocked by the executor's HTTP allowlist.
local function requestGoogleTranslate(text, targetCode)
	local body = httpGet(
		"https://translate.googleapis.com/translate_a/single?client=gtx&sl=auto&tl="
			.. targetCode
			.. "&dt=t&q="
			.. HttpService:UrlEncode(text)
	)
	if body then
		local ok, data = pcall(function()
			return HttpService:JSONDecode(body)
		end)
		if ok and type(data) == "table" and type(data[1]) == "table" then
			local parts = {}
			for _, seg in ipairs(data[1]) do
				if type(seg) == "table" and type(seg[1]) == "string" then
					table.insert(parts, seg[1])
				end
			end
			if #parts > 0 then
				return table.concat(parts)
			end
		end
	end

	body = httpGet(
		"https://clients5.google.com/translate_a/t?client=dict-chrome-ex&sl=auto&tl="
			.. targetCode
			.. "&q="
			.. HttpService:UrlEncode(text)
	)
	if body then
		local ok, data = pcall(function()
			return HttpService:JSONDecode(body)
		end)
		if ok and type(data) == "table" then
			if type(data[1]) == "string" then
				return data[1]
			end
			if type(data[1]) == "table" and type(data[1][1]) == "string" then
				return data[1][1]
			end
		end
	end
	return nil
end

local translateCache = {}
local translateCacheCount = 0
local translateFailWarned = false

local function translateText(text, targetCode)
	if #text > 450 then
		return nil
	end
	local cacheKey = targetCode .. "\1" .. text
	local cached = translateCache[cacheKey]
	if cached ~= nil then
		return cached ~= false and cached or nil
	end

	local result = requestGoogleTranslate(text, targetCode)

	if not result and not translateFailWarned then
		translateFailWarned = true
		if log then
			log(
				"Translation request failed - your executor may be blocking Google Translate domains. Logs will stay untranslated.",
				"Warning"
			)
		end
	end

	if translateCacheCount > 500 then
		table.clear(translateCache)
		translateCacheCount = 0
	end
	translateCache[cacheKey] = result or false
	translateCacheCount += 1
	return result
end

-- Batches translation requests: bursts of log lines are collected for a
-- moment and sent as one newline-joined request, which keeps heavy log
-- volume from hammering the endpoint into rate limits.
local pendingTranslations = {}
local translateQueueRunning = false

local function queueTranslation(text, targetCode, callback)
	local cached = translateCache[targetCode .. "\1" .. text]
	if cached ~= nil then
		pcall(callback, cached ~= false and cached or nil)
		return
	end

	table.insert(pendingTranslations, { text = text, code = targetCode, callback = callback })
	if translateQueueRunning then
		return
	end
	translateQueueRunning = true

	task.spawn(function()
		task.wait(0.25)
		while #pendingTranslations > 0 do
			local code = pendingTranslations[1].code
			local batch = {}
			local totalLen = 0
			while #pendingTranslations > 0 do
				local item = pendingTranslations[1]
				-- Multi-line messages would corrupt the newline-joined batch,
				-- so they always travel alone.
				if item.code ~= code then
					break
				end
				if #batch > 0 and (item.text:find("\n") or totalLen + #item.text + 1 > 400) then
					break
				end
				table.remove(pendingTranslations, 1)
				table.insert(batch, item)
				totalLen += #item.text + 1
				if item.text:find("\n") then
					break
				end
			end

			if #batch == 1 then
				pcall(batch[1].callback, translateText(batch[1].text, code))
			else
				local joined = {}
				for _, item in ipairs(batch) do
					table.insert(joined, item.text)
				end
				local result = translateText(table.concat(joined, "\n"), code)
				local lines = result and string.split(result, "\n") or nil
				if lines and #lines == #batch then
					for i, item in ipairs(batch) do
						pcall(item.callback, (lines[i]:gsub("^%s+", ""):gsub("%s+$", "")))
					end
				else
					-- Line counts diverged (or the batch failed): retry individually
					for _, item in ipairs(batch) do
						pcall(item.callback, translateText(item.text, code))
					end
				end
			end
			task.wait(0.1)
		end
		translateQueueRunning = false
	end)
end

-- === UI localization ===
-- Static UI strings are translated once per language pick; tr() resolves a
-- base English string to its current translation.
local uiTranslations = {}
local localizableStrings = {}
local localizedRefreshers = {}
local localizeRefreshQueued = false

local function registerLocalizedString(s)
	if not table.find(localizableStrings, s) then
		table.insert(localizableStrings, s)
	end
end

local function tr(s)
	return uiTranslations[s] or s
end

local function refreshLocalizedTexts()
	if localizeRefreshQueued then
		return
	end
	localizeRefreshQueued = true
	task.defer(function()
		localizeRefreshQueued = false
		for _, fn in ipairs(localizedRefreshers) do
			pcall(fn)
		end
	end)
end

local function registerLocalizedRefresher(fn)
	table.insert(localizedRefreshers, fn)
end

local function localizeUI()
	table.clear(uiTranslations)
	refreshLocalizedTexts()
	local targetCode = languages[currentLanguageIndex].Code
	if targetCode == "en" then
		return
	end
	for _, s in ipairs(localizableStrings) do
		queueTranslation(s, targetCode, function(translated)
			if translated then
				uiTranslations[s] = translated
				refreshLocalizedTexts()
			end
		end)
	end
end

